{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.py"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "glab@gitlab-skills": true,
    "gopls-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "cost-analyst@cloudzero": true,
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "gitlab-skills": {
      "source": {
        "source": "git",
        "url": "https://gitlab.com/gitlab-org/ai/skills.git"
      }
    },
    "cloudzero": {
      "source": {
        "source": "github",
        "repo": "cloudzero/cloudzero-claude-marketplace"
      }
    }
  },
  "effortLevel": "high"
}
